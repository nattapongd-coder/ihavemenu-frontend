# Frontend Environment Variables

# URL ของ Recipe Service
# สำหรับ local development: http://localhost:5001
# สำหรับ Docker: http://recipe-service:5001
# สำหรับ production: https://your-recipe-service-url.com
RECIPE_SERVICE_URL=http://localhost:5001

# Port ที่ frontend รัน (Vercel จะ set PORT=8000)
PORT=5000
